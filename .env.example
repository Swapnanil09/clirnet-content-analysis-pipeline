# ==============================================================================
# CLIRNET Content Analysis BI pipeline — environment variables
#
# Copy this file to `.env` and fill in real values for LOCAL runs:
#     cp .env.example .env
#
# `.env` is git-ignored — never commit real credentials.
#
# For GitHub Actions, add each of these as a secret in the repository's
# "production" Environment instead (Settings -> Environments -> production
# -> Add secret). See README.md for the full walkthrough.
# ==============================================================================

# ------------------------------------------------------------------------------
# Which month to report on. Format "YYYY-MM". Leave BLANK to default to
# "last calendar month" (recommended for the scheduled monthly run).
# Set it explicitly only for manual backfills, e.g. TARGET_MONTH=2026-03
# ------------------------------------------------------------------------------
TARGET_MONTH=

# ------------------------------------------------------------------------------
# crm-db (PlanetScale) — campaigns + (via @replica) message templates.
# Same host/user/password serve both `crm-db` and `crm-db@replica`; only the
# CRM_DB_REPLICA_DATABASE name differs (defaults to "crm-db@replica" if unset).
# ------------------------------------------------------------------------------
CRM_DB_HOST=aws.connect.psdb.cloud
CRM_DB_USER=
CRM_DB_PASSWORD=
CRM_DB_DATABASE=crm-db
CRM_DB_REPLICA_DATABASE=crm-db@replica

# ------------------------------------------------------------------------------
# shortlink-db (PlanetScale) — shortlink_dictionaries / shortlink_short_urls
# ------------------------------------------------------------------------------
SHORTLINK_DB_HOST=aws.connect.psdb.cloud
SHORTLINK_DB_USER=
SHORTLINK_DB_PASSWORD=
SHORTLINK_DB_DATABASE=shortlink-db

# ------------------------------------------------------------------------------
# notification-shortlink-db (PlanetScale) — notification_temp / notification_logs
# (fallback lookups for anything not yet in ClickHouse)
# ------------------------------------------------------------------------------
NOTIFICATION_SHORTLINK_DB_HOST=aws.connect.psdb.cloud
NOTIFICATION_SHORTLINK_DB_USER=
NOTIFICATION_SHORTLINK_DB_PASSWORD=
NOTIFICATION_SHORTLINK_DB_DATABASE=notification-shortlink-db

# ------------------------------------------------------------------------------
# clirnetdb (PlanetScale) — content tables (MedWiki, video, CME, ...) + user_master
# ------------------------------------------------------------------------------
CLIRNET_DB_HOST=aws.connect.psdb.cloud
CLIRNET_DB_USER=
CLIRNET_DB_PASSWORD=
CLIRNET_DB_DATABASE=clirnetdb

# ------------------------------------------------------------------------------
# ClickHouse Cloud — prod_notification_temp / prod_notification_logs /
# prod_user_activities / prod_short_url_visits
# ------------------------------------------------------------------------------
CLICKHOUSE_HOST=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ------------------------------------------------------------------------------
# SSL CA bundle used for the PlanetScale (pymysql) connections. The default
# below is correct on Ubuntu / GitHub Actions runners — leave it as-is
# unless you're running somewhere else.
# ------------------------------------------------------------------------------
SSL_CA_PATH=/etc/ssl/certs/ca-certificates.crt

# ------------------------------------------------------------------------------
# Outbound email (Office 365 SMTP). EMAIL_PASSWORD should be an app password,
# not your normal account password.
# EMAIL_TO accepts a comma-separated list for multiple recipients.
# ------------------------------------------------------------------------------
EMAIL_FROM=
EMAIL_PASSWORD=
EMAIL_SMTP_SERVER=smtp.office365.com
EMAIL_SMTP_PORT=587
EMAIL_TO=
EMAIL_SIGNOFF_NAME=Swapnanil Chatterjee

# ------------------------------------------------------------------------------
# Optional tuning — safe to leave at defaults. Increase SQL_PAGE_SIZE for
# faster runs on a beefier machine, decrease it if you hit memory limits.
# ------------------------------------------------------------------------------
PIPELINE_DATA_DIR=data
SQL_PAGE_SIZE=100000
ID_BATCH_SIZE=1000
SPEC_BATCH_SIZE=5000
